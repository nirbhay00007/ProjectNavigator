# ═══════════════════════════════════════════════════════════════════════════════
# PROJECT NAVIGATOR — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
# Instructions:
#   1. Copy this file to .env  →  cp .env.example .env
#   2. Fill in all your real values below
#   3. NEVER commit the filled-in .env file — it is already in .gitignore
#
# For cloud deploy, set each variable as an Environment Variable in your
# cloud provider's dashboard (Render, Railway, Vercel, etc.)
# ═══════════════════════════════════════════════════════════════════════════════


# ── Gemini AI API Key ─────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ── Node.js Backend ───────────────────────────────────────────────────────────
PORT=3001


# ── Java AST Backend (Node calls Java for GitHub/Java repos) ──────────────────
JAVA_BACKEND_HOST=localhost
JAVA_BACKEND_PORT=8080


# ══════════════════════════════════════════════════════════════════════════════
# JAVA BACKEND ENVIRONMENT VARIABLES
# Set these in java-backend's environment (or in application.properties locally)
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Local:      jdbc:postgresql://localhost:5432/devclash
# Neon (free): jdbc:postgresql://<host>.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/devclash
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_db_password_here


# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# 1. Go to: https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Add Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
#    (for prod: https://your-java-backend.onrender.com/login/oauth2/code/google)
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_YOUR_GOOGLE_CLIENT_SECRET


# ── JWT Secret ────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-min-32-characters-long


# ── Frontend URL (used by Java backend for post-login OAuth redirect) ─────────
# Local:  http://localhost:5173
# Prod:   https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
