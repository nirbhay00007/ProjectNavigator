spring.application.name=repo_arc_navigator
server.port=8080

spring.web.cors.allowed-origins=http://localhost:3001,http://localhost:3000,http://localhost:5173
spring.web.cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS
spring.web.cors.allowed-headers=*


# ── Database ─────────────────────────────────────────────────────────────────
# Set these as environment variables on your cloud provider (e.g. Render)
spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/devclash}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:postgres}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:}
spring.datasource.driver-class-name=org.postgresql.Driver


# update = alter tables to match entities without dropping data
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.jdbc.lob.non_contextual_creation=true

# These two lines are REQUIRED in Spring Boot 3 / Hibernate 6 for SQL to actually appear in console
logging.level.org.hibernate.SQL=DEBUG
logging.level.org.hibernate.orm.jdbc.bind=TRACE

spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=2
spring.datasource.hikari.idle-timeout=30000

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
spring.security.oauth2.client.registration.google.client-id=${GOOGLE_CLIENT_ID}
spring.security.oauth2.client.registration.google.client-secret=${GOOGLE_CLIENT_SECRET}
spring.security.oauth2.client.registration.google.scope=email,profile

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string (min 32 chars) — generate with: openssl rand -hex 32
app.jwt.secret=${JWT_SECRET:change-me-to-a-long-random-secret-key-256bits}
app.jwt.expiry-minutes=30

# ── Frontend URL (for OAuth redirect after login) ─────────────────────────────
# In production, set this to your Vercel/Netlify URL e.g. https://your-app.vercel.app
app.frontend-url=${FRONTEND_URL:http://localhost:5173}
